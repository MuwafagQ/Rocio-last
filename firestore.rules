rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin check via role field only — no hardcoded emails
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ──────────────────────────────────────────────────────────────
    // Fields written by Admin SDK only (n8n): role, tier, odooCustomerId
    // Fields the user may write: name, phone, avatarUrl, default_address

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId) &&
        request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'phone', 'avatarUrl', 'default_address']) &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email is string;

      // affectedKeys() checks only what changed — safe even when tier/role exist in the doc
      allow update: if isOwner(userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'phone', 'avatarUrl', 'default_address']) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email;

      allow delete: if isAdmin();
    }

    // ── Orders ─────────────────────────────────────────────────────────────
    // App is read-only per architecture contract.
    // All status updates come from n8n via Admin SDK (bypasses rules).

    match /orders/{orderId} {
      // n8n may write the user reference as 'userId' or 'firebase_uid' depending on workflow version
      allow read: if isAuthenticated() && (
        isOwner(resource.data.userId) ||
        isOwner(resource.data.firebase_uid) ||
        isAdmin()
      );

      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasOnly(
          ['userId', 'total', 'status', 'items', 'createdAt', 'deliveryAddress', 'notes', 'paymentMethod']
        ) &&
        request.resource.data.total is number &&
        request.resource.data.total > 0 &&
        request.resource.data.status == 'pending';

      // No client-facing update/delete — Admin SDK (n8n) only
      allow update, delete: if isAdmin();
    }

    // ── App Config ─────────────────────────────────────────────────────────
    // /config/shipping — public read (service-area check runs before login).
    // /config/features — auth required (avoids leaking roadmap to unauthenticated crawlers).
    // All config docs are write-protected; Admin SDK / n8n sets them.

    match /config/shipping {
      allow read: if true;
      allow write: if false;
    }

    match /config/features {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Products & Brands ──────────────────────────────────────────────────
    // Public catalogue — read by anyone, write by admin only.

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Favorites ──────────────────────────────────────────────────────────

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasOnly(['userId', 'productId', 'createdAt']);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // ── Reviews ────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
        isOwner(request.resource.data.userId) &&
        request.resource.data.keys().hasOnly(['userId', 'productId', 'rating', 'comment', 'createdAt']) &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
      allow update: if isAuthenticated() &&
        isOwner(resource.data.userId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'comment', 'updatedAt']);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

  }
}
