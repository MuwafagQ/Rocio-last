rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "Muwafaghussain23@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'name', 'email', 'phone', 'avatarUrl', 'role', 'default_address']) &&
             data.uid is string &&
             data.email is string &&
             (!('name' in data) || data.name is string) &&
             (!('default_address' in data) || data.default_address is string) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidOrder(data) {
      return data.userId is string &&
             data.total is number &&
             data.status in ['pending', 'processing', 'delivered', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidOrder(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin()) && isValidOrder(request.resource.data) &&
                    (request.resource.data.userId == resource.data.userId);
      allow delete: if isAdmin();
    }
  }
}
